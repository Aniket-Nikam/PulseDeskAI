# ─── PulseDesk Docker Environment ──────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.docker.example .env

# Database
DB_PASSWORD=pulsedesk_dev_password_change_me
DB_PORT=5432

# Backend Security (MUST change these in production — minimum 64 characters)
SECRET_KEY=please-change-this-to-a-64-char-random-string-in-production-now
DEVICE_TOKEN_SECRET=please-change-this-device-secret-to-64-chars-minimum-right-now
ALLOW_INSECURE_DEFAULTS=false
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
SCREENSHOT_QUERY_TOKEN_ENABLED=false
AGENT_SIGNATURE_REQUIRED=true

# Frontend URL (used for CORS and links)
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000
BACKEND_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
TRUSTED_HOSTS=["localhost","127.0.0.1"]

# AI (optional — leave GROQ_API_KEY empty to use heuristic fallbacks)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AI_ENABLED=true
AI_SCREENSHOT_ANALYSIS_ENABLED=false

# Logging
DEBUG=false
LOG_LEVEL=INFO
