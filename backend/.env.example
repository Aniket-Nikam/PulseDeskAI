DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/pulsedesk
SECRET_KEY=change-this-to-a-very-long-random-secret-key-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30
DEVICE_TOKEN_SECRET=change-this-device-token-secret-minimum-32-chars
SCREENSHOT_DIR=./screenshots
SCREENSHOT_MAX_SIZE_KB=200
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
LOG_LEVEL=INFO
HEARTBEAT_TIMEOUT_SECONDS=120
IDLE_THRESHOLD_SECONDS=300
BATCH_SIZE_LIMIT=200
RATE_LIMIT_PER_MINUTE=120
