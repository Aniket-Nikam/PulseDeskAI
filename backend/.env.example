DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/pulsedesk
DEBUG=false
SECRET_KEY=replace-with-64-plus-char-random-secret
ALGORITHM=HS256
TOKEN_ISSUER=pulsedesk
TOKEN_AUDIENCE=pulsedesk-admin
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ACCESS_COOKIE_NAME=pulsedesk_access
REFRESH_COOKIE_NAME=pulsedesk_refresh
# Set true in production HTTPS deployments.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/
DEVICE_TOKEN_SECRET=replace-with-64-plus-char-random-device-secret
FRONTEND_URL=https://admin.yourcompany.com
ALLOW_INSECURE_DEFAULTS=false
AI_ENABLED=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AI_SCREENSHOT_ANALYSIS_ENABLED=false
SCREENSHOT_DIR=./screenshots
SCREENSHOT_MAX_SIZE_KB=200
SCREENSHOT_QUERY_TOKEN_ENABLED=true
# Local dev defaults.
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ALLOW_METHODS=["GET","POST","PATCH","PUT","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type","Accept"]
# Add your public domain when testing across networks (for example, your ngrok/cloudflared URL).
TRUSTED_HOSTS=["localhost","127.0.0.1"]
LOG_LEVEL=INFO
HEARTBEAT_TIMEOUT_SECONDS=120
IDLE_THRESHOLD_SECONDS=300
BATCH_SIZE_LIMIT=200
RATE_LIMIT_PER_MINUTE=120
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10
AUTH_REFRESH_RATE_LIMIT_PER_MINUTE=30
ENROLLMENT_RATE_LIMIT_PER_MINUTE=20
JOIN_VERIFY_RATE_LIMIT_PER_MINUTE=12
JOIN_DOWNLOAD_RATE_LIMIT_PER_MINUTE=15
AGENT_UPLOAD_RATE_LIMIT_PER_MINUTE=120
ENROLLMENT_LINK_TTL_HOURS=24
JOIN_CODE_TTL_HOURS=48
JOIN_DOWNLOAD_TOKEN_TTL_MINUTES=20
